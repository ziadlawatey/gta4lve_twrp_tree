# Wait for firmware mount before starting Unisoc security services
on property:twrp.firmware.mounted=true
    start vendor.sprd.storageproxyd
    start vendor.keymint-default
    start vendor.gatekeeper-1-0

# Runs during post-fs-data for File-Based Encryption (FBE)
on property:ro.crypto.state=encrypted && property:twrp.firmware.mounted=true
    start keystore2
    start vendor.gatekeeper-1-0

# Runs after decryption finishes to clean up and save battery
on property:twrp.all.users.decrypted=true
    stop keystore2
    stop vendor.gatekeeper-1-0
    stop vendor.keymint-default
    stop vendor.sprd.storageproxyd
    setprop twrp.firmware.mounted false

# Cleanup for dual space layouts
on property:twrp.decrypt.done=true && property:twrp.user.999.decrypt=0
    setprop twrp.firmware.mounted false

# Clean fallback if user decryption fails or is canceled
on property:of_decryption_failed=true
    setprop twrp.firmware.mounted false

# Clear security mounts if boot mode flips over to fastbootd
on property:ro.twrp.fastbootd=1 && property:twrp.firmware.mounted=true
    setprop twrp.firmware.mounted false

# Safely unmount stock firmware partitions once decryption handling ends
on property:twrp.firmware.mounted=false && property:twrp.firmware.umounted=
    umount /vendor/firmware
    umount /mnt/vendor/persist
    setprop twrp.firmware.umounted true
