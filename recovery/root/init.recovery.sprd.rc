import init.recovery.encryption.rc

on early-init
    loglevel 7
    write /sys/fs/selinux/enforce 0

on early-fs
    # Dynamically resolve and map the Unisoc eMMC storage hardware path via boot properties
    wait /dev/block/platform/soc/${ro.boot.bootdevice}
    symlink /dev/block/platform/soc/${ro.boot.bootdevice} /dev/block/bootdevice

on property:twrp.modules.loaded=true && property:twrp.firmware.loaded=
    mkdir /mnt/vendor 0775 shell system
    mkdir /mnt/vendor/persist 0775 shell system

    # Mount native Unisoc persist storage framework using the clean dynamic symlink
    mount ext4 /dev/block/bootdevice/by-name/persist /mnt/vendor/persist ro
    
    setprop twrp.firmware.mounted true

on late-fs
    # Halt decryption calls safely until the hardware key engine finishes initializing
    exec_start wait_for_keymaster

on fs
    # eMMC Speed Tuning - Optimized for the continuous storage block layout
    write /sys/block/mmcblk0/queue/read_ahead_kb 2048
    write /sys/block/mmcblk0/queue/nr_requests 256

on post-fs-data
    # Force creation of media folders early so TWRP's GUI file manager never freezes up
    mkdir /data/media 0770 media_rw media_rw
    mkdir /data/media/0 0770 media_rw media_rw
    mkdir /data/media/TWRP 0770 media_rw media_rw

on boot
    setprop sys.usb.config mtp,adb
